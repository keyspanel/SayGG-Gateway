# --- Required ---

# Postgres connection string.
# Local Postgres on the VPS:
DATABASE_URL=postgresql://gateway_user:STRONG_PASSWORD@127.0.0.1:5432/gateway_db
# If your DB requires SSL (managed providers like Neon/Supabase/RDS), set:
# DATABASE_SSL=true

# Long random string used to sign JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string

# --- Optional ---

# Port the Node server listens on. Nginx will proxy 443 -> this port.
PORT=5000

# Set to "production" on the VPS.
NODE_ENV=production

# --- Owner seeding (optional, recommended for first install) ---
# When ALL three are set, an owner account is auto-created on first start
# (the password is NEVER overwritten on later restarts). Leave blank if you
# prefer to register an owner via /gateway/register and then promote them
# using OWNER_USERNAMES below.
SEED_OWNER_USERNAME=
SEED_OWNER_EMAIL=
SEED_OWNER_PASSWORD=

# Comma-separated list of usernames or emails that should always have the
# owner role (applied on every start). Use this to promote an existing
# user without storing their password in env.
# OWNER_USERNAMES=youruser
# OWNER_EMAILS=you@example.com
